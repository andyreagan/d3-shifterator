{
  "name": "@andyreagan/d3-shifterator",
  "version": "7.0.0",
  "description": "Build interactive wordshift graphs on the web using D3",
  "main": "dist/shifterator.js",
  "unpkg": "dist/shifterator.js",
  "module": "src/index.js",
  "scripts": {
    "lint": "eslint src",
    "build": "rollup -c",
    "test:unit": "vitest run",
    "pretest:browser": "npm run build",
    "test:browser": "playwright test",
    "test": "npm run lint && npm run test:unit && npm run test:browser",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/**/*.js",
    "src/**/*.js"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andyreagan/d3-shifterator.git"
  },
  "author": "Andy Reagan",
  "license": "BSD-2-Clause",
  "bugs": {
    "url": "https://github.com/andyreagan/d3-shifterator/issues"
  },
  "homepage": "https://github.com/andyreagan/d3-shifterator#readme",
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "eslint": "^10.5.0",
    "rollup": "4.62.0",
    "vitest": "3.2.6"
  },
  "dependencies": {
    "d3": "^7.9.0"
  }
}
